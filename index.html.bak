<script>
    ["selectstart", "dragstart", "contextmenu"].forEach(e => {
        document.addEventListener(e, e => e.preventDefault(), {
            passive: !1
        })
    });
    let touchStartTime = 0,
        longPressTimer = null;
    const clearTimer = () => {
        longPressTimer && (clearTimeout(longPressTimer), longPressTimer = null)
    };
    document.addEventListener("touchstart", e => {
        touchStartTime = Date.now(), clearTimer();
        const t = e.target;
        t.closest("#carousel-container") || t.closest(".cascade-slider_item") || ("IMG" === t.tagName || "VIDEO" === t.tagName || "CANVAS" === t.tagName || t.style.backgroundImage) && (longPressTimer = setTimeout(() => {
            e.preventDefault()
        }, 500))
    }, {
        passive: !1
    }), document.addEventListener("touchmove", clearTimer, {
        passive: !1
    }), document.addEventListener("touchend", e => {
        clearTimer();
        const t = Date.now() - touchStartTime,
            a = e.target;
        a.closest("#carousel-container") || a.closest(".cascade-slider_item") || t > 500 && ("IMG" === a.tagName || "VIDEO" === a.tagName || "CANVAS" === a.tagName || a.style.backgroundImage) && e.preventDefault()
    }, {
        passive: !1
    }), ["gesturestart", "gesturechange", "gestureend"].forEach(e => {
        document.addEventListener(e, e => e.preventDefault(), {
            passive: !1
        })
    })
</script>
