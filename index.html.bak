<script>
    try {
        performance.mark("xp_preload_hint_injected")
    } catch (e) {}
    window.addEventListener("load", () => {
        try {
            const e = document.querySelector('link[href*="xp.css@0.2.6"]');
            e && e.sheet && performance.mark("xp_stylesheet_parsed"), performance.measure("xp_css_parse_interval", "xp_preload_hint_injected", "xp_stylesheet_parsed");
            performance.getEntriesByName("xp_css_parse_interval")[0]
        } catch (e) {}
    })
</script>
