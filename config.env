# XPortfolio Configuration
# This file contains environment variables to customize the XP portfolio

# === IDENTITY CONFIGURATION ===
# How to display the owner's name
# Options: "first", "last", "full", "custom"
NAME_DISPLAY_MODE=first
# If NAME_DISPLAY_MODE is "custom", specify the custom name here
CUSTOM_NAME=MitchIvin

# === SYSTEM BRANDING ===
# OS name shown in welcome message and system dialogs
# Will be combined with NAME_DISPLAY_MODE result (e.g., "Ahmad XP", "MitchIvin XP")
OS_SUFFIX=XP

# === LOGIN SCREEN ===
# Enable/disable profession display on login screen
SHOW_PROFESSION=false
# If SHOW_PROFESSION is true, this overrides the profession from CV.yaml
# Leave empty to use profession from CV.yaml
CUSTOM_PROFESSION=

# === CONTENT PATHS ===
# Path to profile photo (relative to public directory)
PROFILE_PHOTO=profile.jpg
# Path to CV files
CV_YAML_PATH=public/CV.yaml
CV_PDF_PATH=public/CV.pdf

# === USER INTERFACE ASSETS ===
# User profile picture for login screen (relative to root)
USER_LOGIN_ICON=./XP Profile Pics/chess.jpg
# User profile picture for start menu (relative to root)  
USER_START_MENU_ICON=./XP Profile Pics/chess.jpg
# Loading screen logo
LOADING_IMAGE_PATH=./assets/gui/boot/Ahmadxp.png
# Desktop wallpaper
WALLPAPER_DESKTOP_PATH=./assets/gui/bgs/blissorg.jpeg
# Mobile wallpaper
WALLPAPER_MOBILE_PATH=./assets/gui/bgs/blissMobile.webp

# === FEATURE TOGGLES ===
# Show/hide social media in start menu
SHOW_SOCIAL_IN_START_MENU=true
# Show/hide social media in about page
SHOW_SOCIAL_IN_ABOUT=true
# Enable dynamic project loading from markdown files
ENABLE_PROJECT_MARKDOWN=true
# Show projects that don't have markdown files
SHOW_PROJECTS_WITHOUT_MARKDOWN=true

# === CONTENT DIRECTORIES ===
# Directory containing markdown files for different sections
CONTENT_DIR=content
# Directory containing project markdown files
PROJECTS_DIR=content/projects
# About me markdown file
ABOUT_MD=content/about.md

# === UI CUSTOMIZATION ===
# Terminal welcome message customization
TERMINAL_WELCOME_CUSTOM=false
# If TERMINAL_WELCOME_CUSTOM is true, use this message
TERMINAL_WELCOME_MESSAGE=

# === RESUME/PDF VIEWER ===
# How to display PDF resume
# Options: "embed", "download", "new_tab"
PDF_DISPLAY_MODE=embed
# Enable PDF.js for in-browser PDF viewing (set to false for local development to avoid CORS issues)
USE_PDF_JS=true
